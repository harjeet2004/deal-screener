# ── Serper.dev (free Google search — no credit card needed) ──────────────────
SERPER_API_KEY=your_serper_api_key_here

# ── Groq API (Llama 3.3 — free, no credit card — console.groq.com) ───────────
GROQ_API_KEY=your_groq_api_key_here

# ── Email (optional — skip to use download button only) ──────────────────────
# RECIPIENT_EMAIL: address to send the deal memo to
RECIPIENT_EMAIL=your.email@gmail.com

# GMAIL_USER: the Gmail account that sends the email
GMAIL_USER=your.sending.account@gmail.com

# GMAIL_APP_PASSWORD: 16-char App Password (not your normal Gmail password).
# Enable 2-Step Verification first, then:
#   myaccount.google.com → Security → App passwords → Mail → Generate
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
