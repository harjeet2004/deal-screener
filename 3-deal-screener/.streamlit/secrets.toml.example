# ── Streamlit Cloud secrets — copy this structure into the Streamlit Cloud dashboard ──
# Go to: share.streamlit.io → your app → Settings → Secrets
# Paste the keys below (without the .example extension, with real values).

# Required: search + AI
SERPER_API_KEY  = "your_serper_api_key_here"
GROQ_API_KEY    = "your_groq_api_key_here"

# Required: email recipient
RECIPIENT_EMAIL = "you@example.com"

# Optional: enables Gmail email delivery on Streamlit Cloud.
# Paste the full contents of your local token.json here as a single-line string.
# Leave this out if you only want the download button (email will be skipped).
# GMAIL_TOKEN_JSON = '{"token": "...", "refresh_token": "...", ...}'
