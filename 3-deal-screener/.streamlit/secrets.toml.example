# ── Streamlit Cloud secrets — copy this structure into the Streamlit Cloud dashboard ──
# Go to: share.streamlit.io → your app → Settings → Secrets
# Paste the keys below (without the .example extension, with real values).

# Required: search + AI
SERPER_API_KEY  = "your_serper_api_key_here"
GROQ_API_KEY    = "your_groq_api_key_here"

# Optional: enables email delivery.
# Without these three, the pipeline still runs and produces a downloadable PPTX.

# Address the deal memo is sent to (can be the same as GMAIL_USER)
RECIPIENT_EMAIL = "you@example.com"

# Gmail account used to send the email
GMAIL_USER = "your.sending.account@gmail.com"

# 16-character App Password (NOT your normal Gmail password).
# How to get one:
#   1. Enable 2-Step Verification on your Google account
#   2. Go to myaccount.google.com → Security → App passwords
#   3. Select "Mail" + "Other (custom name)" → Generate
#   4. Paste the 16-char code here (spaces are fine)
GMAIL_APP_PASSWORD = "xxxx xxxx xxxx xxxx"
